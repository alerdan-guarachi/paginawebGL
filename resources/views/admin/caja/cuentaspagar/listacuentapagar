                                                                    <script>
                                                                        function updateTotal(selector, outputId) {
                                                                            let total = 0;
                                                                            const fechaSeleccionada = document.getElementById('fechaSeleccionada')?.value;
                                                                            document.querySelectorAll(selector + ':checked').forEach(cb => {
                                                                                const fecha = cb.dataset.fecha;
                                                                                if (fecha === fechaSeleccionada) {
                                                                                    total += parseFloat(cb.dataset.total) || 0;
                                                                                }
                                                                            });
                                                                            document.getElementById(outputId).textContent = total.toFixed(2);
                                                                            updateTotalGeneral();
                                                                        }

                                                                        function updateTotalGeneral() {
                                                                            const cuentas = parseFloat(document.getElementById('total-cuentas').textContent) || 0;
                                                                            const programaciones = parseFloat(document.getElementById('total-programaciones').textContent) || 0;
                                                                            const total = cuentas + programaciones;
                                                                            document.getElementById('total-general').textContent = total.toFixed(2);
                                                                        }

                                                                        // CUENTAS
                                                                        document.getElementById('select-all-cuentas').addEventListener('change', function() {
                                                                            let checked = this.checked;
                                                                            document.querySelectorAll('.select-item-cuentas, .select-group-cuentas').forEach(cb => cb.checked = checked);
                                                                            updateTotal('.select-item-cuentas', 'total-cuentas');
                                                                        });

                                                                        document.querySelectorAll('.select-group-cuentas').forEach(groupCheckbox => {
                                                                            groupCheckbox.addEventListener('change', function() {
                                                                                let group = this.dataset.group;
                                                                                document.querySelectorAll(`.select-c-${group}`).forEach(cb => cb.checked = this.checked);
                                                                                updateTotal('.select-item-cuentas', 'total-cuentas');
                                                                            });
                                                                        });

                                                                        document.querySelectorAll('.select-item-cuentas').forEach(item => {
                                                                            item.addEventListener('change', () => updateTotal('.select-item-cuentas', 'total-cuentas'));
                                                                        });

                                                                        // PROGRAMACIONES
                                                                        document.getElementById('select-all-programaciones')?.addEventListener('change', function() {
                                                                            let checked = this.checked;
                                                                            document.querySelectorAll('.select-item-programaciones, .select-group-programaciones').forEach(cb => cb.checked = checked);
                                                                            updateTotal('.select-item-programaciones', 'total-programaciones');
                                                                        });

                                                                        document.querySelectorAll('.select-group-programaciones').forEach(groupCheckbox => {
                                                                            groupCheckbox.addEventListener('change', function() {
                                                                                let group = this.dataset.group;
                                                                                document.querySelectorAll(`.select-p-${group}`).forEach(cb => cb.checked = this.checked);
                                                                                updateTotal('.select-item-programaciones', 'total-programaciones');
                                                                            });
                                                                        });

                                                                        document.querySelectorAll('.select-item-programaciones').forEach(item => {
                                                                            item.addEventListener('change', () => updateTotal('.select-item-programaciones', 'total-programaciones'));
                                                                        });
                                                                    </script>
                                                                    <script>
                                                                        function aprobarSeleccionados() {
                                                                            const cuentasIds = Array.from(document.querySelectorAll('.select-item-cuentas:checked'))
                                                                                .map(cb => cb.closest('tr').querySelector('td:nth-child(2)').textContent.trim());

                                                                            const programacionesIds = Array.from(document.querySelectorAll('.select-item-programaciones:checked'))
                                                                                .map(cb => cb.closest('tr').querySelector('td:nth-child(2)').textContent.trim());

                                                                            const fechaSeleccionada = document.getElementById('fechaSeleccionada').value;

                                                                            fetch('{{ route('aprobar.registros') }}', {
                                                                                method: 'POST',
                                                                                headers: {
                                                                                    'Content-Type': 'application/json',
                                                                                    'X-CSRF-TOKEN': document.querySelector('meta[name="csrf-token"]').content
                                                                                },
                                                                                body: JSON.stringify({
                                                                                    cuentas: cuentasIds,
                                                                                    programaciones: programacionesIds,
                                                                                    fecha: fechaSeleccionada
                                                                                })
                                                                            })
                                                                            .then(res => res.json())
                                                                            .then(data => {
                                                                                alert(data.message);
                                                                                location.reload();
                                                                            })
                                                                            .catch(err => {
                                                                                console.error(err);
                                                                                alert("Ocurrió un error al aprobar los registros.");
                                                                            });
                                                                        }
                                                                    </script>
